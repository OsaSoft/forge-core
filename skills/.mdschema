frontmatter:
    fields:
        - name: name
          type: string
        - name: description
          type: string
        - name: version
          type: string

heading_rules:
    no_skip_levels: true
    max_depth: 3

structure:
    - heading:
          pattern: "^# .+"
          regex: true
      allow_additional: true
      children:
          - heading:
                pattern: "## Workflow Routing"
            optional: true
            tables:
                - min: 1
          - heading:
                pattern: "## Constraints"
            optional: true
            lists:
                - min: 1
