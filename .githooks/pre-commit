#!/usr/bin/env bash
set -euo pipefail

# forge module pre-commit hook
# Canonical source: https://github.com/N4M3Z/forge-cli/blob/main/templates/git/pre-commit

SCRIPT_URL="https://raw.githubusercontent.com/N4M3Z/forge-cli/main/scripts/validate.sh"
SCRIPT_SHA="e5fea8f10359807b72e719d9e475eb0257de9df8303a0476fd639b6f882832e7"

if command -v forge >/dev/null 2>&1; then
    forge validate .
    exit $?
fi

script=$(curl -sfL "$SCRIPT_URL" 2>/dev/null || true)
if [ -z "$script" ]; then
    echo "error: forge not installed and validate.sh unreachable"
    echo "  install forge-cli: https://github.com/N4M3Z/forge-cli"
    exit 1
fi

actual=$(echo "$script" | shasum -a 256 | cut -d' ' -f1)
if [ "$actual" != "$SCRIPT_SHA" ]; then
    echo "error: validate.sh hash mismatch (expected $SCRIPT_SHA, got $actual)"
    echo "  update SCRIPT_SHA in .githooks/pre-commit after verifying the new script"
    exit 1
fi

echo "$script" | bash -s -- .
