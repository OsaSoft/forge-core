{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://github.com/N4M3Z/forge-core/schemas/forge-adr.schema.json",
    "title": "Forge ADR Frontmatter",
    "description": "JSON Schema for validating forge ADR YAML frontmatter (structured-madr + x-forge- extensions)",
    "type": "object",
    "required": [
        "title",
        "description",
        "type",
        "category",
        "tags",
        "status",
        "created",
        "updated",
        "author",
        "project"
    ],
    "properties": {
        "title": {
            "type": "string",
            "description": "Short descriptive title for the decision",
            "minLength": 1,
            "maxLength": 100
        },
        "description": {
            "type": "string",
            "description": "One-sentence summary of the decision",
            "minLength": 1,
            "maxLength": 300
        },
        "type": {
            "type": "string",
            "description": "Document type identifier",
            "const": "adr"
        },
        "category": {
            "type": "string",
            "description": "The category of decision",
            "minLength": 1
        },
        "tags": {
            "type": "array",
            "description": "Keywords for categorization and search",
            "minItems": 1,
            "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$|^[a-z0-9]$"
            },
            "uniqueItems": true
        },
        "status": {
            "type": "string",
            "description": "Current status of the decision",
            "enum": ["proposed", "accepted", "deprecated", "superseded"]
        },
        "created": {
            "type": "string",
            "description": "Date the ADR was created (ISO 8601)",
            "format": "date"
        },
        "updated": {
            "type": "string",
            "description": "Date the ADR was last modified (ISO 8601)",
            "format": "date"
        },
        "author": {
            "type": "string",
            "description": "The author or team responsible for the decision",
            "minLength": 1
        },
        "project": {
            "type": "string",
            "description": "The project this decision applies to",
            "minLength": 1
        },
        "technologies": {
            "type": "array",
            "description": "Technologies referenced or affected by this decision",
            "items": {
                "type": "string",
                "minLength": 1
            },
            "uniqueItems": true
        },
        "audience": {
            "type": "array",
            "description": "Intended readers of this ADR",
            "items": {
                "type": "string",
                "minLength": 1
            },
            "uniqueItems": true
        },
        "related": {
            "type": "array",
            "description": "Filenames of related ADRs",
            "items": {
                "type": "string"
            },
            "uniqueItems": true
        },
        "responsible": {
            "type": "array",
            "description": "RACI: who does the work",
            "items": {
                "type": "string"
            }
        },
        "x-forge-responsible": {
            "$ref": "#/properties/responsible"
        },
        "accountable": {
            "type": "array",
            "description": "RACI: who approves the decision",
            "items": {
                "type": "string"
            }
        },
        "x-forge-accountable": {
            "$ref": "#/properties/accountable"
        },
        "consulted": {
            "type": "array",
            "description": "RACI: whose input is sought",
            "items": {
                "type": "string"
            }
        },
        "x-forge-consulted": {
            "$ref": "#/properties/consulted"
        },
        "informed": {
            "type": "array",
            "description": "RACI: who is notified of the outcome",
            "items": {
                "type": "string"
            }
        },
        "x-forge-informed": {
            "$ref": "#/properties/informed"
        },
        "upstream": {
            "type": "array",
            "description": "Rules or artifacts promoted from this ADR, or provenance sources",
            "items": {
                "type": "string"
            }
        },
        "x-forge-upstream": {
            "$ref": "#/properties/upstream"
        }
    },
    "additionalProperties": true
}
